<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFF9E6">

    <!-- Titre de l'app -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=" Thread &amp; AsyncTask Lab"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#C2185B"
        android:gravity="center"
        android:padding="30dp"
        android:paddingBottom="2dp"/>

    <!-- Ligne de séparation décorative -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#FFCA28"
        android:layout_marginBottom="12dp"/>

    <!-- Zone de statut avec fond coloré -->
    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Statut : prêt"
        android:textSize="15sp"
        android:textColor="#5D4037"
        android:background="#FCE4EC"
        android:padding="12dp"
        android:layout_marginBottom="14dp"/>

    <!-- ProgressBar horizontale stylisée -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#FFCA28"
        android:progressBackgroundTint="#F8BBD0"
        android:visibility="invisible"
        android:layout_marginBottom="16dp"/>

    <!-- ImageView centrée avec bordure rose -->
    <ImageView
        android:id="@+id/img"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#FFE082"
        android:padding="8dp"
        android:contentDescription="Image chargée"/>

    <!-- Bouton 1 : charger image -->
    <Button
        android:id="@+id/btnLoadThread"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📷  Charger image (Thread)"
        android:backgroundTint="#FFCA28"
        android:textColor="#4E342E"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <!-- Bouton 2 : calcul lourd -->
    <Button
        android:id="@+id/btnCalcAsync"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚙️  Calcul lourd (AsyncTask)"
        android:backgroundTint="#F48FB1"
        android:textColor="#4E342E"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <!-- Bouton 3 : Toast -->
    <Button
        android:id="@+id/btnToast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔔  Afficher Toast"
        android:backgroundTint="#FFE082"
        android:textColor="#4E342E"
        android:textStyle="bold"/>

</LinearLayout>